{
  "name": "continia-demo-generator",
  "version": "0.1.0",
  "description": "Automated demo video generator for Continia Banking in Business Central",
  "type": "module",
  "bin": {
    "generate-demo": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "generate-demo": "node dist/cli.js",
    "prepare": "husky",
    "lint": "eslint --cache src/",
    "lint:fix": "eslint --cache --fix src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "business-central",
    "demo",
    "video",
    "playwright",
    "bc-replay"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@microsoft/bc-replay": "^0.1.119",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ffmpeg-static": "^5.3.0",
    "openai": "^6.29.0",
    "playwright": "^1.55.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "**/*.ts": ["eslint --fix", "prettier --write"]
  }
}
